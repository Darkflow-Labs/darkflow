{
  "name": "@darkflow/js",
  "version": "0.0.1-alpha",
  "description": "Official Darkflow TypeScript SDK for developers",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/darkflow.cjs.js",
  "module": "./dist/darkflow.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/darkflow.es.js",
      "require": "./dist/darkflow.cjs.js"
    },
    "./sync": "./src/sync/wsStream.ts",
    "./sync-types": "./src/sync/types.ts",
    "./geyser": "./src/geyser/index.ts",
    "./geyser-types": "./src/geyser/types.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "check:bundle-size": "node ./scripts/checkBundleSize.mjs"
  },
  "peerDependencies": {
    "effect": "^3.20.0",
    "ofetch": "^1.4.0",
    "ws": "^8.18.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "ofetch": "^1.4.1",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4",
    "ws": "^8.18.3"
  },
  "keywords": [
    "darkflow",
    "sdk",
    "solana",
    "websocket"
  ],
  "license": "MIT",
  "private": false
}
