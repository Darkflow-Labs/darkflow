SYNC_WS_HOST=0.0.0.0
SYNC_WS_PORT=8791
SYNC_WS_MAX_CLIENTS=200
# Same Unkey verify root pattern as Onyx launch stream
SYNC_UNKEY_VERIFY_ROOT_KEY=
# Optional: require meta.purpose on client keys
# SYNC_REQUIRE_META_PURPOSE=desk_price_stream
REDIS_PUBSUB_ADAPTER=redis
# Must match Onyx REDIS_PUBSUB_URL when using redis adapter
REDIS_URL=redis://127.0.0.1:6379
# Used when REDIS_PUBSUB_ADAPTER=upstash
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
REDIS_PRICE_TICK_CHANNEL=df:price:tick
# SYNC_LOG_PRETTY=true
