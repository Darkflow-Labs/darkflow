# --- Autumn + Guardian billing (optional) ---
# Postgres URL must match the Better Auth database when billing is enabled (Prisma `User` lookup).
DATABASE_URL=
AUTUMN_SECRET_KEY=
# Feature IDs from `autumn.config.ts` after `npx atmn push` (sandbox/prod).
AUTUMN_FEATURE_LAUNCH_STREAM=launch_stream_message
AUTUMN_FEATURE_TRADE_ENTRY=onyx_live_trading
AUTUMN_FEATURE_PLATFORM_TRADE_FEE=platform_trade_fee_usd
# Better Auth user id for the bot operator (must exist in `user` table + Autumn customer).
ONYX_BILLING_CUSTOMER_ID=
ONYX_BILLING_STREAM_ENABLED=false
ONYX_BILLING_TRADE_ENABLED=false
# Default 1500 = 15% of buy notional in USD (uses ONYX_ESTIMATED_SOL_USD × buy SOL).
ONYX_PLATFORM_TRADE_FEE_BPS=1500
# Zero upstream / Drizzle: separate Postgres for `sync.price_bar` + `sync.price_latest` (see packages/database Drizzle migrations).
SYNC_DATABASE_URL=
# Optional hot last-price cache (REST). Writers no-op when unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Pub/sub fanout to apps/sync (adapter + channel).
REDIS_PUBSUB_ADAPTER=redis
REDIS_PUBSUB_URL=redis://127.0.0.1:6379
# When adapter=upstash, pub/sub also uses REST credentials above.
REDIS_PRICE_TICK_CHANNEL=df:price:tick
ONYX_SOL_USD_FEED_ENABLED=true
# Pyth Pro Lazer (recommended)
# Never expose this in frontend code.
ONYX_PYTH_PRO_ACCESS_TOKEN=
# SOL/USD feed id from Symbols List API (default 6)
ONYX_PYTH_PRO_SOL_USD_FEED_ID=6
ONYX_PYTH_PRO_SOL_USD_EXPONENT=-8
ONYX_PYTH_PRO_CHANNEL=fixed_rate@200ms
ONYX_MARKET_SYNC_ENABLED=true
ONYX_MARKET_SYNC_BAR_THROTTLE_MS=450
ONYX_MARKET_SYNC_BAR_BUCKET_MS=500
# Unkey keys for the stream must include JSON metadata: { "userId": "<Better Auth user id>" }.
# Cache tradeoffs: Guardian uses short TTLs on Autumn `check` and invalidates on successful `track`.
# GUARDIAN_AUTUMN_CHECK_CACHE_MS / GUARDIAN_UNKEY_VERIFY_CACHE_MS — see packages/guardian (optional future env wiring).
