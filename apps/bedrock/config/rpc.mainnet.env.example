BEDROCK_IDENTITY_KEYPAIR=/home/sol/validator-keypair.json
BEDROCK_LEDGER_DIR=/mnt/ledger
BEDROCK_ACCOUNTS_DIR=/mnt/accounts
BEDROCK_LOG_PATH=/home/sol/agave-rpc-mainnet.log

BEDROCK_RPC_BIND_ADDRESS=0.0.0.0
BEDROCK_RPC_PORT=8899
# Agave requires at least 27 ports (inclusive); 8000-8026 is the documented minimum.
BEDROCK_DYNAMIC_PORT_RANGE=8000-8030

BEDROCK_ENTRYPOINT_1=entrypoint.mainnet-beta.solana.com:8001
BEDROCK_ENTRYPOINT_2=entrypoint2.mainnet-beta.solana.com:8001
BEDROCK_ENTRYPOINT_3=entrypoint3.mainnet-beta.solana.com:8001
BEDROCK_EXPECTED_GENESIS_HASH=REPLACE_WITH_MAINNET_GENESIS_HASH

BEDROCK_KNOWN_VALIDATOR_1=REPLACE_WITH_KNOWN_VALIDATOR_1
BEDROCK_KNOWN_VALIDATOR_2=REPLACE_WITH_KNOWN_VALIDATOR_2
BEDROCK_KNOWN_VALIDATOR_3=REPLACE_WITH_KNOWN_VALIDATOR_3
BEDROCK_KNOWN_VALIDATOR_4=REPLACE_WITH_KNOWN_VALIDATOR_4

BEDROCK_GEYSER_PLUGIN_CONFIG=/home/sol/yellowstone-grpc-geyser/config.json
# Optional override: if set, start-rpc.sh writes a runtime config with this libpath.
# Useful when your plugin config libpath is stale or differs by host.
# Typical macOS build output:
# /Users/<you>/.../yellowstone-grpc/target/release/libyellowstone_grpc_geyser.dylib
# Typical Linux build output:
# /home/sol/.../yellowstone-grpc/target/release/libyellowstone_grpc_geyser.so
BEDROCK_GEYSER_PLUGIN_LIBPATH=
BEDROCK_RAYON_NUM_THREADS=1

BEDROCK_LIMIT_LEDGER_SIZE=true
BEDROCK_FULL_RPC_API=true
BEDROCK_PRIVATE_RPC=true
BEDROCK_NO_VOTING=true
# Skip PoH hash-rate startup check (recommended for RPC-only nodes on slower CPUs/VMs).
BEDROCK_NO_POH_SPEED_TEST=true
